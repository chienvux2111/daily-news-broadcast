# === Telegram (Required) ===
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# === AI Provider Selection ===
# Supported: claude, openai, groq, gemini, qwen, deepseek, ollama, openrouter, together, custom, none
# Set to "none" to test the pipeline without any AI (outputs raw article list)
AI_PROVIDER=claude
# AI_MODEL=              # Optional: override default model for chosen provider

# === AI API Keys (only the one matching AI_PROVIDER is required) ===
ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...
# QWEN_API_KEY=sk-...               # Alibaba DashScope
# DEEPSEEK_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# TOGETHER_API_KEY=...

# === Ollama (local, no API key needed) ===
# OLLAMA_BASE_URL=http://localhost:11434/v1

# === Custom OpenAI-compatible provider ===
# CUSTOM_AI_API_KEY=...
# CUSTOM_AI_BASE_URL=https://your-api.com/v1
# CUSTOM_AI_MODEL=your-model
# CUSTOM_AI_NAME=My AI

# === Cache ===
CACHE_TYPE=file
CACHE_PATH=./.cache/news.json
# REDIS_URL=redis://localhost:6379

# === Schedule & Tuning ===
CRON_SCHEDULE=0 7 * * *
SUMMARY_LANGUAGE=vi
MAX_ARTICLES_PER_SOURCE=3
CONCURRENCY_LIMIT=5

# === Drip Mode ===
DRIP_BATCH_SIZE=5              # Articles per cron run
DRIP_DELAY_MS=3600000          # 60min between each article

# === Auth for Cloudflare manual trigger ===
# TRIGGER_SECRET=your_secret
