# === Required (depends on which plugins you use) ===
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=-100xxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx

# === Optional AI keys (only needed if using that provider) ===
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...

# === Cache ===
CACHE_TYPE=file
CACHE_PATH=./.cache/news.json
# REDIS_URL=redis://localhost:6379

# === Schedule & Tuning ===
CRON_SCHEDULE=0 7 * * *
SUMMARY_LANGUAGE=vi
MAX_ARTICLES_PER_SOURCE=3
CONCURRENCY_LIMIT=5

# === Auth for Cloudflare manual trigger ===
# TRIGGER_SECRET=your_secret
