{
  "streams": [
    {
      "id": "morning-tech-digest",
      "name": "Morning Tech Digest",
      "enabled": true,
      "cron": "0 7 * * *",
      "timezone": "Asia/Ho_Chi_Minh",
      "sources": [
        { "type": "preset", "preset": "bigTechBlogs" },
        { "type": "preset", "preset": "communitySources" }
      ],
      "ai": {
        "provider": "claude",
        "apiKey": "$ANTHROPIC_API_KEY",
        "model": "claude-sonnet-4-20250514",
        "language": "vi",
        "style": "digest",
        "audience": "nguoi lam IT Viet Nam: developers, engineers, product, data, security, operations, technical leaders",
        "platform": "telegram"
      },
      "outputs": [
        {
          "type": "telegram",
          "config": {
            "botToken": "$TELEGRAM_BOT_TOKEN",
            "chatId": "$TELEGRAM_CHAT_ID"
          }
        }
      ],
      "options": {
        "concurrency": 5,
        "maxArticlesPerSource": 3
      }
    },
    {
      "id": "ai-news-evening",
      "name": "AI/ML Evening Brief",
      "enabled": true,
      "cron": "0 18 * * 1-5",
      "timezone": "Asia/Ho_Chi_Minh",
      "sources": [
        { "type": "preset", "preset": "aiMLBlogs" },
        { "type": "hackernews", "config": { "query": "LLM transformer", "minPoints": 80 } },
        { "type": "reddit", "config": { "subreddit": "LocalLLaMA", "minUpvotes": 100 } }
      ],
      "ai": {
        "provider": "groq",
        "apiKey": "$GROQ_API_KEY",
        "model": "llama-3.3-70b-versatile",
        "language": "vi",
        "style": "bullet"
      },
      "outputs": [
        {
          "type": "slack",
          "config": {
            "webhookUrl": "$SLACK_WEBHOOK_URL"
          }
        },
        {
          "type": "markdown",
          "config": {
            "outputDir": "./digests"
          }
        }
      ],
      "options": {
        "concurrency": 3,
        "maxArticlesPerSource": 5
      }
    },
    {
      "id": "ai-pulse-daily",
      "name": "AI Pulse Daily",
      "enabled": false,
      "cron": "0 8,14 * * *",
      "timezone": "Asia/Ho_Chi_Minh",
      "sources": [
        { "type": "preset", "preset": "aiNewsSources" },
        { "type": "preset", "preset": "aiDeepDiveSources" }
      ],
      "ai": {
        "provider": "claude",
        "apiKey": "$ANTHROPIC_API_KEY",
        "language": "vi",
        "style": "bullet"
      },
      "outputs": [
        {
          "type": "telegram",
          "config": {
            "botToken": "$TELEGRAM_BOT_TOKEN",
            "chatId": "$TELEGRAM_CHAT_ID"
          }
        }
      ],
      "options": {
        "concurrency": 5,
        "maxArticlesPerSource": 2
      }
    },
    {
      "id": "devops-weekly",
      "name": "DevOps Weekly Roundup",
      "enabled": false,
      "cron": "0 9 * * 1",
      "timezone": "UTC",
      "sources": [
        { "type": "preset", "preset": "devopsSources" },
        { "type": "rss", "config": { "id": "k8s-blog", "name": "Kubernetes Blog", "feedUrl": "https://kubernetes.io/feed.xml", "icon": "☸️", "category": "DevOps" } }
      ],
      "ai": {
        "provider": "openai",
        "apiKey": "$OPENAI_API_KEY",
        "model": "gpt-4o-mini",
        "language": "vi",
        "style": "newsletter"
      },
      "outputs": [
        {
          "type": "discord",
          "config": {
            "webhookUrl": "$DISCORD_WEBHOOK_URL"
          }
        }
      ]
    }
  ]
}
